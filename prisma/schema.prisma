generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RequestStatus {
  PENDING
  NEGOTIATING
  APPROVED
  REJECTED
  CANCELLED
}

enum TransactionType {
  SYSTEM_DEDUCTION
  SYSTEM_REFUND
  MANUAL_ADJUSTMENT
}

model Designation {
  id               String   @id @default(cuid())
  name             String   @unique
  isActive         Boolean  @default(true)
  users            User[]
  nodes            HierarchyNode[]
  leaveAllocations LeaveAllocationRule[]
  pendingRegistrations PendingRegistration[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  users       User[]
  nodes       HierarchyNode[]
  pendingRegistrations PendingRegistration[]
}

model User {
  id              String         @id @default(cuid())
  email           String         @unique
  password        String
  isAdmin         Boolean        @default(false)
  name            String
  
  designationId   String?
  departmentId    String?
  avatar          String?
  
  // The hierarchy is completely handled by the HierarchyNode map!
  
  designation     Designation?   @relation(fields: [designationId], references: [id])
  department      Department?    @relation(fields: [departmentId], references: [id])

  leaveBalances   LeaveBalance[]
  leavesApplied   LeaveRequest[] @relation("Applicant")
  auditLogs       LeaveAuditLog[] @relation("Actor")
  transactions    LeaveBalanceTransaction[] @relation("UserTransactions")
  performedTransactions LeaveBalanceTransaction[] @relation("PerformedByTransactions")

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model HierarchyNode {
  id              String   @id @default(cuid())
  designationId   String
  departmentId    String
  x               Float?   @default(50)
  y               Float?   @default(50)
  isObserver      Boolean  @default(false)
  
  // The connections
  designation     Designation @relation(fields: [designationId], references: [id])
  department      Department  @relation(fields: [departmentId], references: [id])
  parents         HierarchyNode[] @relation("NodeHierarchy")
  children        HierarchyNode[] @relation("NodeHierarchy")

  // The queue of leaves waiting for THIS ROLE to approve them
  pendingApprovals LeaveRequest[] @relation("NodeApprover")
  auditLogs        LeaveAuditLog[]

  // Ensure only one node exists per combination
  @@unique([departmentId, designationId]) 
}

model LeaveType {
  id            String   @id @default(cuid())
  name          String   @unique
  defaultDays   Int
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  leaveRequests LeaveRequest[]
  leaveBalances LeaveBalance[]
  allocations   LeaveAllocationRule[]
  transactions  LeaveBalanceTransaction[]
}

model LeaveAllocationRule {
  id             String      @id @default(cuid())
  leaveTypeId    String
  designationId  String
  allocatedDays  Int
  createdAt      DateTime    @default(now())

  leaveType      LeaveType   @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  designation    Designation @relation(fields: [designationId], references: [id], onDelete: Cascade)

  @@unique([leaveTypeId, designationId])
}

model LeaveBalance {
  id          String    @id @default(cuid())
  userId      String
  leaveTypeId String
  totalDays   Int       
  usedDays    Int       @default(0)
  year        Int       

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)
  transactions LeaveBalanceTransaction[]

  @@unique([userId, leaveTypeId, year])
}

model LeaveBalanceTransaction {
  id              String          @id @default(cuid())
  userId          String
  leaveTypeId     String
  amount          Int
  reason          String
  performedById   String?
  transactionType TransactionType
  createdAt       DateTime        @default(now())

  // Relations
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade, name: "UserTransactions")
  performedBy     User?         @relation(fields: [performedById], references: [id], onDelete: SetNull, name: "PerformedByTransactions")
  leaveType       LeaveType     @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)
  leaveBalanceId  String?
  leaveBalance    LeaveBalance? @relation(fields: [leaveBalanceId], references: [id], onDelete: Cascade)
}

model LeaveRequest {
  id              String        @id @default(cuid())
  applicantId     String
  leaveTypeId     String
  fromDate        DateTime
  toDate          DateTime
  subject         String?
  reason          String        // Will store rich text HTML/JSON from Novel editor
  status          RequestStatus @default(PENDING)
  
  // Negotiation fields
  managerSuggestedFromDate DateTime?
  managerSuggestedToDate   DateTime?
  overrideReason           String?
  
  leaveType       LeaveType     @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)
  applicant       User          @relation("Applicant", fields: [applicantId], references: [id], onDelete: Cascade)
  pendingAtNodes  HierarchyNode[] @relation("NodeApprover")

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  auditLogs       LeaveAuditLog[]
}

model LeaveAuditLog {
  id              String        @id @default(cuid())
  leaveRequestId  String
  action          String        // e.g., SUBMITTED, APPROVED, REJECTED, PROPOSED_DATES
  actorId         String        // User who performed the action
  nodeId          String?       // The HierarchyNode they acted as (null if applicant)
  createdAt       DateTime      @default(now())

  leaveRequest    LeaveRequest  @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)
  actor           User          @relation("Actor", fields: [actorId], references: [id], onDelete: Cascade)
  node            HierarchyNode? @relation(fields: [nodeId], references: [id], onDelete: SetNull)
}

model Holiday {
  id          String   @id @default(cuid())
  name        String
  date        DateTime @unique
}

model PendingRegistration {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED
  
  departmentId  String?
  designationId String?
  department    Department?  @relation(fields: [departmentId], references: [id])
  designation   Designation? @relation(fields: [designationId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}
