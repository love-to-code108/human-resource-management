generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model Designation {
  id          String   @id @default(cuid())
  name        String   @unique
  isActive    Boolean  @default(true)
  users         User[]
  nodes         HierarchyNode[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  users       User[]
  nodes       HierarchyNode[]
}

model User {
  id              String         @id @default(cuid())
  email           String         @unique
  password        String
  isAdmin         Boolean        @default(false)
  name            String
  
  designationId   String?
  departmentId    String?
  
  // The hierarchy is completely handled by the HierarchyNode map!
  
  designation     Designation?   @relation(fields: [designationId], references: [id])
  department      Department?    @relation(fields: [departmentId], references: [id])

  leaveBalances   LeaveBalance[]
  leavesApplied   LeaveRequest[] @relation("Applicant")

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model HierarchyNode {
  id              String   @id @default(cuid())
  designationId   String
  departmentId    String
  parentId        String?
  
  // The connections
  designation     Designation @relation(fields: [designationId], references: [id])
  department      Department  @relation(fields: [departmentId], references: [id])
  parent          HierarchyNode?  @relation("NodeHierarchy", fields: [parentId], references: [id])
  children        HierarchyNode[] @relation("NodeHierarchy")

  // The queue of leaves waiting for THIS ROLE to approve them
  pendingApprovals LeaveRequest[] @relation("NodeApprover")

  // Ensure only one node exists per combination
  @@unique([departmentId, designationId]) 
}

model LeaveType {
  id          String         @id @default(cuid())
  name        String         @unique
  defaultDays Int            
  isActive    Boolean        @default(true) 

  balances    LeaveBalance[]
  requests    LeaveRequest[]

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model LeaveBalance {
  id          String    @id @default(cuid())
  userId      String
  leaveTypeId String
  totalDays   Int       
  usedDays    Int       @default(0)
  year        Int       

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)

  @@unique([userId, leaveTypeId, year])
}

model LeaveRequest {
  id              String        @id @default(cuid())
  applicantId     String
  leaveTypeId     String
  fromDate        DateTime
  toDate          DateTime
  reason          String        // Will store rich text HTML/JSON from Novel editor
  status          RequestStatus @default(PENDING)
  
  pendingAtNodeId String?
  
  leaveType       LeaveType     @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)
  applicant       User          @relation("Applicant", fields: [applicantId], references: [id])
  pendingAtNode   HierarchyNode? @relation("NodeApprover", fields: [pendingAtNodeId], references: [id])

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Holiday {
  id          String   @id @default(cuid())
  name        String
  date        DateTime @unique
}
